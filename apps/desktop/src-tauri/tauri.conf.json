{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sofvary",
  "version": "0.1.0",
  "identifier": "com.sofvary.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Sofvary",
        "width": 1200,
        "height": 760,
        "minWidth": 920,
        "minHeight": 620,
        "visible": true,
        "decorations": false
      },
      {
        "label": "command",
        "title": "Sofvary Command",
        "width": 760,
        "height": 620,
        "minWidth": 640,
        "minHeight": 520,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "transparent": true
      },
      {
        "label": "glyph",
        "title": "Sofvary",
        "width": 52,
        "height": 52,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: http://127.0.0.1:*; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:*; frame-src http://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/icon.icns"
    ]
  }
}
