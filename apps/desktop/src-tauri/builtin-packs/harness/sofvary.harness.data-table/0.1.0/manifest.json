{
  "schemaVersion": "1.0",
  "type": "sofvary.harness-pack",
  "id": "sofvary.harness.data-table",
  "version": "0.1.0",
  "name": "Data Table Harness",
  "description": "Constrains data table apps to local JSON data, safe CSV placeholders, and table CRUD/search behavior.",
  "compatibility": {
    "client": ">=0.1.0",
    "os": {
      "windows": {
        "supported": true,
        "minVersion": "10.0.17763"
      },
      "macos": {
        "supported": true,
        "minVersion": "12.0"
      },
      "linux": {
        "supported": true
      }
    },
    "arch": [
      "x64",
      "arm64"
    ]
  },
  "runtime": "sofvary.runtime.data-table",
  "integrity": {},
  "promptPolicy": "prompt/policy.json",
  "builtin": true
}
