{
  "schemaVersion": "1.0",
  "type": "sofvary.harness-pack",
  "id": "sofvary.harness.file-processor",
  "version": "0.1.0",
  "name": "File Processor Harness",
  "description": "Constrains file processor apps to explicit file selection, read-only startup, dry-run preview, confirmation, and operation logs.",
  "compatibility": {
    "client": ">=0.1.0",
    "os": {
      "windows": {
        "supported": true,
        "minVersion": "10.0.17763"
      },
      "macos": {
        "supported": true,
        "minVersion": "12.0"
      },
      "linux": {
        "supported": true
      }
    },
    "arch": [
      "x64",
      "arm64"
    ]
  },
  "runtime": "sofvary.runtime.file-processor",
  "integrity": {},
  "promptPolicy": "prompt/policy.json",
  "builtin": true
}
