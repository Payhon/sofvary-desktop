{
  "schemaVersion": "1.0",
  "type": "sofvary.harness-pack",
  "id": "sofvary.harness.desktop-widget",
  "version": "0.1.0",
  "name": "Desktop Widget Harness",
  "description": "Constrains desktop widget apps to compact preview-contained UI without transparent windows or system automation.",
  "compatibility": {
    "client": ">=0.1.0",
    "os": {
      "windows": {
        "supported": true,
        "minVersion": "10.0.17763"
      },
      "macos": {
        "supported": true,
        "minVersion": "12.0"
      },
      "linux": {
        "supported": true
      }
    },
    "arch": [
      "x64",
      "arm64"
    ]
  },
  "runtime": "sofvary.runtime.desktop-widget",
  "integrity": {},
  "promptPolicy": "prompt/policy.json",
  "builtin": true
}
