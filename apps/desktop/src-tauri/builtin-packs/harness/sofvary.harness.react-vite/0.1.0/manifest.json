{
  "schemaVersion": "1.0",
  "type": "sofvary.harness-pack",
  "id": "sofvary.harness.react-vite",
  "version": "0.1.0",
  "name": "React + Vite Harness",
  "description": "Constrains React + Vite generation to a workspace-local TypeScript app without external UI frameworks or CDN assets.",
  "compatibility": {
    "client": ">=0.1.0",
    "os": {
      "windows": {
        "supported": true,
        "minVersion": "10.0.17763"
      },
      "macos": {
        "supported": true,
        "minVersion": "12.0"
      },
      "linux": {
        "supported": true
      }
    },
    "arch": [
      "x64",
      "arm64"
    ]
  },
  "runtime": "sofvary.runtime.react-vite",
  "integrity": {},
  "promptPolicy": "prompt/policy.json",
  "builtin": true
}
