{
  "schemaVersion": "1.0",
  "type": "sofvary.runtime-pack",
  "id": "sofvary.runtime.desktop-widget",
  "version": "0.1.0",
  "name": "Desktop Widget Runtime",
  "description": "Runs compact desktop widget apps inside the main Sofvary preview.",
  "compatibility": {
    "client": ">=0.1.0",
    "os": {
      "windows": {
        "supported": true,
        "minVersion": "10.0.17763"
      },
      "macos": {
        "supported": true,
        "minVersion": "12.0"
      },
      "linux": {
        "supported": true
      }
    },
    "arch": [
      "x64",
      "arm64"
    ]
  },
  "stack": {
    "frontend": "React",
    "language": "TypeScript",
    "bundler": "Vite",
    "database": "None",
    "server": "Vite local dev server"
  },
  "runtime": {
    "kind": "desktop-widget",
    "generatedRoot": "generated",
    "entrypoint": "react/src/main.tsx",
    "bind": "127.0.0.1",
    "network": "local-only"
  },
  "commands": {
    "install": {
      "executable": "${sidecar:pnpm}",
      "args": [
        "install",
        "--offline",
        "--ignore-scripts"
      ],
      "cwd": "generated/react",
      "allowedNetwork": false,
      "timeoutMs": 60000,
      "killOnDrop": true
    },
    "dev": {
      "executable": "${sidecar:pnpm}",
      "args": [
        "exec",
        "vite",
        "--host",
        "127.0.0.1",
        "--port",
        "${port}"
      ],
      "cwd": "generated/react",
      "allowedNetwork": false,
      "killOnDrop": true
    },
    "build": {
      "executable": "${sidecar:pnpm}",
      "args": [
        "run",
        "build"
      ],
      "cwd": "generated/react",
      "allowedNetwork": false,
      "timeoutMs": 120000,
      "killOnDrop": true
    }
  },
  "defaultHarness": [
    "sofvary.harness.desktop-widget"
  ],
  "integrity": {},
  "executor": {
    "kind": "react-project",
    "allowedTopLevelDirs": [
      "widget",
      "react"
    ],
    "clearRoots": [
      "generated/widget",
      "generated/react"
    ],
    "contextRoot": "generated",
    "requiredToolchains": [
      "nodejs"
    ]
  },
  "promptEnvelope": "prompt/envelope.json",
  "selection": {
    "softwareType": "Desktop Widget",
    "reason": "The request sounds like a compact timer, countdown, quick note, or small desktop utility.",
    "signals": [
      "pomodoro",
      "timer",
      "countdown",
      "widget",
      "quick note",
      "small dashboard",
      "番茄钟",
      "计时",
      "倒计时",
      "小组件",
      "便签",
      "桌面组件",
      "小面板"
    ],
    "weight": 4,
    "priority": 50
  },
  "builtin": true
}
