{
  "schemaVersion": "1.0",
  "type": "sofvary.runtime-pack",
  "id": "sofvary.runtime.data-table",
  "version": "0.1.0",
  "name": "Data Table Runtime",
  "description": "Runs isolated personal data table apps with workspace-local JSON data and React UI.",
  "compatibility": {
    "client": ">=0.1.0",
    "os": {
      "windows": {
        "supported": true,
        "minVersion": "10.0.17763"
      },
      "macos": {
        "supported": true,
        "minVersion": "12.0"
      },
      "linux": {
        "supported": true
      }
    },
    "arch": [
      "x64",
      "arm64"
    ]
  },
  "stack": {
    "frontend": "React",
    "language": "TypeScript",
    "bundler": "Vite",
    "database": "JSON",
    "server": "Vite local dev server"
  },
  "runtime": {
    "kind": "data-table",
    "generatedRoot": "generated",
    "entrypoint": "react/src/main.tsx",
    "bind": "127.0.0.1",
    "network": "local-only"
  },
  "commands": {
    "install": {
      "executable": "${sidecar:pnpm}",
      "args": [
        "install",
        "--offline",
        "--ignore-scripts"
      ],
      "cwd": "generated/react",
      "allowedNetwork": false,
      "timeoutMs": 60000,
      "killOnDrop": true
    },
    "dev": {
      "executable": "${sidecar:pnpm}",
      "args": [
        "exec",
        "vite",
        "--host",
        "127.0.0.1",
        "--port",
        "${port}"
      ],
      "cwd": "generated/react",
      "allowedNetwork": false,
      "killOnDrop": true
    },
    "build": {
      "executable": "${sidecar:pnpm}",
      "args": [
        "run",
        "build"
      ],
      "cwd": "generated/react",
      "allowedNetwork": false,
      "timeoutMs": 120000,
      "killOnDrop": true
    }
  },
  "defaultHarness": [
    "sofvary.harness.data-table"
  ],
  "integrity": {},
  "executor": {
    "kind": "react-project",
    "allowedTopLevelDirs": [
      "data",
      "react"
    ],
    "clearRoots": [
      "generated/data",
      "generated/react"
    ],
    "contextRoot": "generated",
    "requiredToolchains": [
      "nodejs"
    ]
  },
  "promptEnvelope": "prompt/envelope.json",
  "selection": {
    "softwareType": "Data Table Tool",
    "reason": "The request is centered on tabular data, filtering, sorting, CSV, or lightweight data cleaning.",
    "signals": [
      "table",
      "spreadsheet",
      "csv",
      "inventory",
      "budget",
      "filter",
      "sort",
      "data cleaning",
      "data cleanup",
      "表格",
      "数据表",
      "CSV",
      "库存",
      "预算",
      "筛选",
      "排序",
      "数据清洗",
      "清洗页面"
    ],
    "weight": 4,
    "priority": 70
  },
  "builtin": true
}
