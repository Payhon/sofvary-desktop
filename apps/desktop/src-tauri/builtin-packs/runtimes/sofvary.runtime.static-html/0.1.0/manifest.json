{
  "schemaVersion": "1.0",
  "type": "sofvary.runtime-pack",
  "id": "sofvary.runtime.static-html",
  "version": "0.1.0",
  "name": "Static HTML Runtime",
  "description": "Runs isolated HTML, CSS, and JavaScript from generated/static through Sofvary's local static server.",
  "compatibility": {
    "client": ">=0.1.0",
    "os": {
      "windows": {
        "supported": true,
        "minVersion": "10.0.17763"
      },
      "macos": {
        "supported": true,
        "minVersion": "12.0"
      },
      "linux": {
        "supported": true
      }
    },
    "arch": [
      "x64",
      "arm64"
    ]
  },
  "stack": {
    "frontend": "HTML",
    "language": "JavaScript",
    "bundler": "None",
    "database": "None",
    "server": "Sofvary local static server"
  },
  "runtime": {
    "kind": "static-html",
    "generatedRoot": "generated/static",
    "entrypoint": "index.html",
    "bind": "127.0.0.1",
    "network": "local-only"
  },
  "commands": {},
  "defaultHarness": [
    "sofvary.harness.static-html"
  ],
  "integrity": {},
  "executor": {
    "kind": "static-html",
    "allowedTopLevelDirs": [
      "static"
    ],
    "clearRoots": [
      "generated/static"
    ],
    "contextRoot": "generated/static",
    "requiredToolchains": []
  },
  "promptEnvelope": "prompt/envelope.json",
  "selection": {
    "softwareType": "Lightweight Page Tool",
    "reason": "The request can be served as a small single-page tool without package installation or local data services.",
    "signals": [
      "landing page",
      "single page",
      "calculator",
      "simple tool",
      "static",
      "页面",
      "单页",
      "计算器",
      "轻量",
      "简单工具",
      "静态"
    ],
    "weight": 2,
    "priority": 10
  },
  "builtin": true
}
