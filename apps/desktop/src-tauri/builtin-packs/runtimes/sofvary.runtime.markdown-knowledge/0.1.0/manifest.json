{
  "schemaVersion": "1.0",
  "type": "sofvary.runtime-pack",
  "id": "sofvary.runtime.markdown-knowledge",
  "version": "0.1.0",
  "name": "Markdown Knowledge Runtime",
  "description": "Runs isolated Markdown knowledge apps from workspace-local React and Markdown files.",
  "compatibility": {
    "client": ">=0.1.0",
    "os": {
      "windows": {
        "supported": true,
        "minVersion": "10.0.17763"
      },
      "macos": {
        "supported": true,
        "minVersion": "12.0"
      },
      "linux": {
        "supported": true
      }
    },
    "arch": ["x64", "arm64"]
  },
  "stack": {
    "frontend": "React",
    "language": "TypeScript",
    "bundler": "Vite",
    "database": "JSON",
    "server": "Vite local dev server"
  },
  "runtime": {
    "kind": "markdown-knowledge",
    "generatedRoot": "generated",
    "entrypoint": "react/src/main.tsx",
    "bind": "127.0.0.1",
    "network": "local-only"
  },
  "commands": {
    "install": {
      "executable": "${sidecar:pnpm}",
      "args": ["install", "--offline", "--ignore-scripts"],
      "cwd": "generated/react",
      "allowedNetwork": false,
      "timeoutMs": 60000,
      "killOnDrop": true
    },
    "dev": {
      "executable": "${sidecar:pnpm}",
      "args": ["exec", "vite", "--host", "127.0.0.1", "--port", "${port}"],
      "cwd": "generated/react",
      "allowedNetwork": false,
      "killOnDrop": true
    },
    "build": {
      "executable": "${sidecar:pnpm}",
      "args": ["run", "build"],
      "cwd": "generated/react",
      "allowedNetwork": false,
      "timeoutMs": 120000,
      "killOnDrop": true
    }
  },
  "defaultHarness": ["sofvary.harness.markdown-knowledge"],
  "integrity": {}
}
