{
  "schemaVersion": "1.0",
  "type": "sofvary.runtime-pack",
  "id": "sofvary.runtime.file-processor",
  "version": "0.1.0",
  "name": "File Processor Runtime",
  "description": "Runs isolated local file processor apps with explicit selection, dry-run previews, and operation logs.",
  "compatibility": {
    "client": ">=0.1.0",
    "os": {
      "windows": {
        "supported": true,
        "minVersion": "10.0.17763"
      },
      "macos": {
        "supported": true,
        "minVersion": "12.0"
      },
      "linux": {
        "supported": true
      }
    },
    "arch": [
      "x64",
      "arm64"
    ]
  },
  "stack": {
    "frontend": "React",
    "language": "TypeScript",
    "bundler": "Vite",
    "database": "None",
    "server": "Vite local dev server"
  },
  "runtime": {
    "kind": "file-processor",
    "generatedRoot": "generated",
    "entrypoint": "react/src/main.tsx",
    "bind": "127.0.0.1",
    "network": "local-only"
  },
  "commands": {
    "install": {
      "executable": "${sidecar:pnpm}",
      "args": [
        "install",
        "--offline",
        "--ignore-scripts"
      ],
      "cwd": "generated/react",
      "allowedNetwork": false,
      "timeoutMs": 60000,
      "killOnDrop": true
    },
    "dev": {
      "executable": "${sidecar:pnpm}",
      "args": [
        "exec",
        "vite",
        "--host",
        "127.0.0.1",
        "--port",
        "${port}"
      ],
      "cwd": "generated/react",
      "allowedNetwork": false,
      "killOnDrop": true
    },
    "build": {
      "executable": "${sidecar:pnpm}",
      "args": [
        "run",
        "build"
      ],
      "cwd": "generated/react",
      "allowedNetwork": false,
      "timeoutMs": 120000,
      "killOnDrop": true
    }
  },
  "defaultHarness": [
    "sofvary.harness.file-processor"
  ],
  "integrity": {},
  "executor": {
    "kind": "react-project",
    "allowedTopLevelDirs": [
      "file-processor",
      "react"
    ],
    "clearRoots": [
      "generated/file-processor",
      "generated/react"
    ],
    "contextRoot": "generated",
    "requiredToolchains": [
      "nodejs"
    ]
  },
  "promptEnvelope": "prompt/envelope.json",
  "selection": {
    "softwareType": "File Processor",
    "reason": "The request is about explicit local files, batch operations, or safe dry-run processing.",
    "signals": [
      "batch rename",
      "rename files",
      "folder",
      "files",
      "file processor",
      "organize images",
      "批量重命名",
      "重命名",
      "文件处理",
      "整理文件",
      "文件夹",
      "图片整理"
    ],
    "weight": 5,
    "priority": 65
  },
  "builtin": true
}
